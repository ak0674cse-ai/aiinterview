```cpp
// common/cpp/recovery/wal_log.h
#pragma once
#include <string>
#include <fstream>
#include <mutex>
#include <cstdint>

namespace recorder {

// WAL entry format (binary, append-only)
struct WALEntry {
    uint64_t timestampUs;
    uint64_t sessionId;
    uint32_t type;           // 0=checkpoint, 1=frame, 2=audio, 3=error
    uint64_t videoPts;
    uint64_t audioPts;
    uint64_t fileOffset;
    uint32_t encoderStateHash;
    uint32_t checksum;       // CRC32 of entry
};

class WALLog {
public:
    explicit WALLog(const std::string& basePath);
    
    // Append entry (fsync every 5 entries for durability)
    void append(const WALEntry& entry);
    
    // Read all entries for recovery
    std::vector<WALEntry> readAll();
    
    // Truncate log after successful finalize
    void clear();
    
    // Check for incomplete session
    bool hasIncompleteSession(uint64_t& outSessionId);
    
private:
    std::string logPath_;
    std::ofstream writer_;
    std::mutex mutex_;
