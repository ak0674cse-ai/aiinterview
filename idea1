```dart
// lib/src/recovery/crash_recovery.dart
import 'dart:io';

/// Manages recovery from app crashes during recording.
/// 
/// On app launch, checks WAL for incomplete sessions and attempts recovery.
class CrashRecovery {
  final WALLog _wal;
  final CheckpointManager _checkpoints;
  final MP4Repair _mp4Repair;
  
  CrashRecovery(this._wal, this._checkpoints, this._mp4Repair);
  
  /// Check for and recover incomplete session
  /// 
  /// Returns recovered file path if successful, null otherwise.
  Future<String?> recoverIfNeeded() async {
    final sessionId = await _wal.getIncompleteSession();
    if (sessionId == null) return null;
    
    // Load latest checkpoint
    final checkpoint = await _checkpoints.loadLatest(sessionId);
    if (checkpoint == null) {
      // No checkpoint — can't recover
      await _cleanup(sessionId);
      return null;
    }
    
    // Validate partial MP4
    final partialFile = File(_getFilePath(sessionId));
    if (!await partialFile.exists()) {
      await _cleanup(sessionId);
      return null;
    }
    
    // Repair MP4 (fix moov atom if truncated)
    final repaired = await _mp4Repair.repair(
      inputPath: partialFile.path,
      checkpoint: checkpoint,
    );
    
    if (repaired != null) {
      await _wal.clear(sessionId);
      await _checkpoints.clear(sessionId);
      
      // Trigger background upload of recovered file
      await _queueUpload(repaired);
    }
    
    return repaired;
  }
  
  Future<void> _cleanup(String sessionId) async {
    await _wal.clear(sessionId);
    await _checkpoints.clear(sessionId);
    
    final file = File(_getFilePath(sessionId));
    if (await file.exists()) await file.delete();
  }
  
  String _getFilePath(String sessionId) {
    final dir = Directory.systemTemp;
    return '${dir.path}/recording_$sessionId.mp4';
  }
}
