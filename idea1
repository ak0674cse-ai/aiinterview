// lib/src/core/recording_session.dart
import 'dart:async';
import 'dart:typed_data';

/// State machine for a single recording session.
/// 
/// States: idle → initializing → recording → paused → finalizing → completed
///                                    ↓___________________________↑
///                                    error (terminal)
class RecordingSession {
  final String sessionId;
  final NativeRecorderApi _nativeApi;
  final PluginRegistry _plugins;
  final MetricsCollector _metrics;
  final Stream<RecordingEvent> _eventStream;
  
  SessionState _state = SessionState.idle;
  final _stateController = StreamController<SessionState>.broadcast();
  final _progressController = StreamController<RecordingProgress>.broadcast();
  
  Timer? _metricsTimer;
  DateTime? _startTime;
  
  RecordingSession({
    required this.sessionId,
    required NativeRecorderApi nativeApi,
    required PluginRegistry plugins,
    required MetricsCollector metrics,
    required Stream<RecordingEvent> eventStream,
  }) : _nativeApi = nativeApi,
       _plugins = plugins,
       _metrics = metrics,
       _eventStream = eventStream;
  
  SessionState get state => _state;
  bool get isComplete => _state == SessionState.completed || _state == SessionState.error;
  Stream<SessionState> get stateStream => _stateController.stream;
  Stream<RecordingProgress> get progressStream => _progressController.stream;
  
  /// Start recording
  /// 
  /// Transitions: idle → initializing → recording
  Future<void> start() async {
    _assertState(SessionState.idle);
    
    _transitionTo(SessionState.initializing);
    
    try {
      // Begin native recording
      final filePath = await _nativeApi.startRecording();
      
      _startTime = DateTime.now();
      _transitionTo(SessionState.recording);
      
      // Start metrics collection
      _startMetricsCollection();
      
      _metrics.recordEvent('session_started', {
        'session_id': sessionId,
        'file_path': filePath,
      });
      
    } catch (e) {
      _transitionTo(SessionState.error);
      rethrow;
    }
  }
  
  /// Push AI TTS audio to the recording
  /// 
  /// PCM data should be 48kHz, 16-bit, stereo interleaved.
  Future<void> pushTTS(Uint8List pcmData) async {
    _assertState(SessionState.recording);
    
    final timestampUs = _elapsedMicroseconds;
    await _nativeApi.pushTtsAudio(pcmData, timestampUs);
  }
  
  /// Notify native side of new Flutter frame
  /// 
  /// Called by FrameCapture scheduler at 30fps.
  Future<void> onFrameRendered(FlutterFrame frame) async {
    if (_state != SessionState.recording) return;
    
    await _nativeApi.onFlutterFrame(frame);
  }
  
  /// Pause recording (keep session alive)
  Future<void> pause() async {
    _assertState(SessionState.recording);
    await _nativeApi.pauseRecording();
    _transitionTo(SessionState.paused);
  }
  
  /// Resume paused recording
  Future<void> resume() async {
    _assertState(SessionState.paused);
    await _nativeApi.resumeRecording();
    _transitionTo(SessionState.recording);
  }
  
  /// Stop recording and finalize MP4
  /// 
  /// Transitions: recording → finalizing → completed
  Future<RecordingResult> stop() async {
    _assertState(SessionState.recording, SessionState.paused);
    
    _transitionTo(SessionState.finalizing);
    _stopMetricsCollection();
    
    try {
      final result = await _nativeApi.stopRecording();
      
      _transitionTo(SessionState.completed);
      
      _metrics.recordEvent('session_completed', {
        'session_id': sessionId,
        'duration_ms': result.durationMs,
        'file_size': result.fileSizeBytes,
      });
      
      return result;
      
    } catch (e) {
      _transitionTo(SessionState.error);
      rethrow;
    }
  }
  
  // Internal
  void _transitionTo(SessionState newState) {
    _state = newState;
    _stateController.add(newState);
  }
  
  void _assertState(SessionState expected, [SessionState? alt]) {
    if (_state != expected && _state != alt) {
      throw RecorderException(
        code: 'INVALID_STATE',
        message: 'Expected $expected, got $_state',
      );
    }
  }
  
  int get _elapsedMicroseconds {
    if (_startTime == null) return 0;
    return DateTime.now().difference(_startTime!).inMicroseconds;
  }
  
  void _startMetricsCollection() {
    _metricsTimer = Timer.periodic(const Duration(seconds: 5), (_) async {
      final metrics = await _nativeApi.getStatus() as PerformanceMetrics;
      _progressController.add(RecordingProgress(
        cpuUsage: metrics.cpuUsage,
        memoryMB: metrics.memoryUsageMB,
        actualFps: metrics.actualFps,
        droppedFrames: metrics.droppedFrames,
      ));
    });
  }
  
  void _stopMetricsCollection() => _metricsTimer?.cancel();
}
