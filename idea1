```dart
// lib/src/core/flutter_recorder.dart
import 'dart:async';
import 'dart:typed_data';

/// Commercial-grade Flutter recording SDK.
/// 
/// Singleton pattern ensures only one recording session exists at a time.
/// Thread-safe across all platforms.
class FlutterRecorder {
  static FlutterRecorder? _instance;
  static final _lock = Object();
  
  final NativeRecorderApi _nativeApi;
  final PluginRegistry _plugins;
  final MetricsCollector _metrics;
  
  RecordingSession? _activeSession;
  final _eventController = StreamController<RecordingEvent>.broadcast();
  
  // Private constructor
  FlutterRecorder._(this._nativeApi, this._plugins, this._metrics);
  
  /// Get singleton instance
  static Future<FlutterRecorder> getInstance() async {
    if (_instance != null) return _instance!;
    
    // Initialize native bridge
    final nativeApi = NativeRecorderApi();
    final plugins = PluginRegistry();
    final metrics = MetricsCollector();
    
    _instance = FlutterRecorder._(nativeApi, plugins, metrics);
    return _instance!;
  }
  
  /// Initialize SDK with configuration
  /// 
  /// Must be called before creating any sessions.
  /// Idempotent — safe to call multiple times.
  Future<void> initialize(RecorderConfig config) async {
    _metrics.recordEvent('sdk_initialize', {
      'resolution': '${config.video.width}x${config.video.height}',
      'fps': config.video.fps,
    });
    
    // Validate configuration
    _validateConfig(config);
    
    // Initialize native layer
    await _nativeApi.initialize(config);
    
    // Initialize plugins
    await _plugins.initialize(config);
  }
  
  /// Create a new recording session
  /// 
  /// Throws [RecorderException] if a session is already active.
  Future<RecordingSession> createSession() async {
    if (_activeSession != null && !_activeSession!.isComplete) {
      throw RecorderException(
        code: 'SESSION_ACTIVE',
        message: 'Another recording session is already active',
      );
    }
    
    final sessionId = _generateSessionId();
    _activeSession = RecordingSession(
      sessionId: sessionId,
      nativeApi: _nativeApi,
      plugins: _plugins,
      metrics: _metrics,
      eventStream: _eventController.stream,
    );
    
    return _activeSession!;
  }
  
  /// Register a custom plugin implementation
  /// 
  /// Allows customers to inject their own encoders, upload backends, etc.
  void registerPlugin<T extends Plugin>(PluginType type, PluginFactory<T> factory) {
    _plugins.register(type, factory);
  }
  
  /// Get current recording status
  Future<RecordingStatus> getStatus() => _nativeApi.getStatus();
  
  /// Release all resources
  /// 
  /// Terminates any active recording. Call on app shutdown.
  Future<void> dispose() async {
    if (_activeSession != null) {
      await _activeSession!.stop();
    }
    await _nativeApi.release();
    await _eventController.close();
    _instance = null;
  }
  
  // Internal
  void _validateConfig(RecorderConfig config) {
    assert(config.video.width > 0 && config.video.height > 0);
    assert(config.video.fps == 30 || config.video.fps == 60);
    assert(config.audio.sampleRate == 48000);
  }
  
  String _generateSessionId() {
    return '${DateTime.now().millisecondsSinceEpoch}_${_randomString(8)}';
  }
  
  String _randomString(int length) {
    const chars = 'abcdefghijklmnopqrstuvwxyz0123456789';
    return List.generate(length, (_) => chars[DateTime.now().microsecond % chars.length]).join();
  }
}
