## 6. Memory Optimization

```cpp
// common/cpp/memory/buffer_pool.h
#pragma once
#include <vector>
#include <memory>
#include <mutex>

namespace recorder {

// Fixed-size buffer for frame data
struct FrameBuffer {
    static constexpr size_t SIZE = 1920 * 1080 * 4;  // 1080p RGBA
    alignas(64) uint8_t data[SIZE];
    bool inUse = false;
};

// Object pool for frame buffers
class FrameBufferPool {
public:
    static constexpr int POOL_SIZE = 3;  // Triple buffering
    
    FrameBufferPool() {
        buffers_.reserve(POOL_SIZE);
        for (int i = 0; i < POOL_SIZE; i++) {
            buffers_.push_back(std::make_unique<FrameBuffer>());
        }
    }
    
    // Acquire buffer (non-blocking, returns null if all in use)
    FrameBuffer* acquire() {
        std::lock_guard<std::mutex> lock(mutex_);
        for (auto& buf : buffers_) {
            if (!buf->inUse) {
                buf->inUse = true;
                return buf.get();
            }
        }
        return nullptr;  // All buffers in use — drop frame
    }
    
    void release(FrameBuffer* buf) {
        std::lock_guard<std::mutex> lock(mutex_);
        buf->inUse = false;
    }
    
private:
    std::vector<std::unique_ptr<FrameBuffer>> buffers_;
    std::mutex mutex_;
};

// Memory arena for audio processing
class MemoryArena {
public:
    explicit MemoryArena(size_t size = 64 * 1024 * 1024);  // 64MB
    
    void* allocate(size_t size);
    void reset();  // Reset bump pointer (O(1))
    
private:
    std::vector<uint8_t> memory_;
    size_t offset_ = 0;
};

} // namespace recorder
